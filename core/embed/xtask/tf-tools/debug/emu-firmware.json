{
    "type": "cppdbg",
    "request": "launch",
    "program": "${tfTools.executablePath}",
    "args": [
        "-m",
        "main"
    ],
    "cwd": "${workspaceFolder}/core/src",
    "environment": [
        {
            "name": "TREZOR_DISABLE_ANIMATION",
            "value": "1"
        }
    ],
    "linux": {
        "MIMode": "gdb",
        "miDebuggerPath": "gdb"
    },
    "MIMode": "lldb",
    "stopAtEntry": true
}
